{
  "name": "axiom",
  "version": "1.0.0",
  "description": "Axiom — OSINT Intelligence Investigation Platform",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "date-fns": "^3.3.1",
    "dompurify": "^3.0.9",
    "lucide-react": "^0.323.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.1",
    "reactflow": "^11.10.4",
    "remark-gfm": "^4.0.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.1"
  },
  "build": {
    "appId": "com.osint-intell.axiom",
    "productName": "Axiom",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
